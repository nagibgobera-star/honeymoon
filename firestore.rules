rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /activities/{activityId} {
      // Public itinerary is read-only for everyone (no login on index.html).
      allow read: if true;

      // Writes require an authenticated client (admin.html signs in anonymously
      // after the password gate) and a document that matches the expected shape.
      allow create, update: if request.auth != null && isValidActivity(request.resource.data);
      allow delete: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidActivity(data) {
      return data.day is int && data.day >= 1 && data.day <= 90 &&
             data.order is int && data.order >= 0 &&
             data.done is bool &&
             data.date is string && data.date.size() <= 200 &&
             data.city is string && data.city.size() <= 100 &&
             data.time is string && data.time.size() <= 50 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             (data.mapsUrl == null || (data.mapsUrl is string && data.mapsUrl.size() <= 500)) &&
             (data.pdfUrl  == null || (data.pdfUrl  is string && data.pdfUrl.size()  <= 500)) &&
             data.type in ['transporte', 'visita', 'almuerzo', 'cena', 'hotel', 'tour', 'libre'];
    }
  }
}
