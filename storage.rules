rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /docs/{activityId}/{fileName} {
      // Public itinerary needs to open/download attached PDFs without login.
      allow read: if true;

      // Uploads require an authenticated client (admin.html signs in anonymously
      // after the password gate), and must be a PDF under 20MB — same limits
      // already enforced client-side in admin.html's upload handler.
      allow write: if request.auth != null &&
                      request.resource.size <= 20 * 1024 * 1024 &&
                      request.resource.contentType == 'application/pdf';
      allow delete: if request.auth != null;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
